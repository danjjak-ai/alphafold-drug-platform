# 🧬 Discovery Core - .gitignore

# ─── Python ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
cython_debug/

# ─── Virtual Environments ────────────────────────
.venv/
venv/
env/
ENV/
lib/
lib64/
bin/
include/
share/
pyvenv.cfg

# ─── Environment Variables ───────────────────────
.env
.env.*
!.env.example

# ─── Trained Models (Large Files) ────────────────
# Use Git LFS for these if needed
models/
!models/.gitkeep

# ─── Database ────────────────────────────────────
# Runtime database
data/mg_discovery.db*
!data/mg_discovery.db

# ─── Structural Data ─────────────────────────────
# Ignores large structure files, allows specific samples for demo
data/structures/predicted/
data/structures/ligands/*.pdbqt
data/structures/ligands/*.pdb
data/structures/targets/*.pdbqt
data/structures/targets/*.pdb
!data/structures/targets/7ql6_raw.pdb
!data/structures/targets/8s9p_raw.pdb
!data/structures/.gitkeep

# ─── Simulation Results ──────────────────────────
# Default to ignore all results, allow demo samples
results/docking/*.pdbqt
results/docking/*.pdb
results/docking/*.log
!results/docking/chrna1_CHEMBL21333_out.pdbqt
!results/docking/chrna1_CHEMBL1200640_out.pdbqt
!results/docking/chrna1_CHEMBL941_out.pdbqt
!results/docking/chrna1_CHEMBL2105762_out.pdbqt
!results/docking/chrna1_CHEMBL1201131_out.pdbqt
!results/docking/.gitkeep
results/top_candidates.csv

# ─── Jupyter Notebook ────────────────────────────
.ipynb_checkpoints/
*.ipynb
!Discovery_Core_Colab_Pipeline.ipynb

# ─── IDE / Editor / OS ───────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.AppleDouble
.LSOverride

# ─── Logs & Temp ─────────────────────────────────
*.log
logs/
tmp/
temp/
*.tmp
*.bak

# ─── Streamlit & Dashboard ───────────────────────
.streamlit/secrets.toml
web/demo_assets/

# ─── AutoDock Vina Binaries ──────────────────────
# Excludes binary distributions; keep placeholder files
vina_bin/windows/vina.exe
vina_bin/linux/vina
vina_bin/mac/vina
!vina_bin/windows/.gitkeep
!vina_bin/linux/.gitkeep
!vina_bin/mac/.gitkeep

# Note: scripts/vina.exe is intentionally included if it exists in that location
# as a core dependency for the Windows environment.
